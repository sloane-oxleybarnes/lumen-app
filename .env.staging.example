# Beckett staging / Vercel Preview
NEXT_PUBLIC_APP_ENV=staging
APP_ENV=staging
NEXT_PUBLIC_SITE_URL=https://your-staging-url.vercel.app

# Separate Supabase project for staging only
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me

# Admin and automation
ADMIN_PASSWORD=replace_me
CRON_SECRET=replace_me

# AI usage. Use real keys only when you want realistic staging coaching.
ANTHROPIC_API_KEY=replace_me
BETA_DAILY_AI_LIMIT=30
BETA_DAILY_COURSE_LIMIT=40
BETA_UNLIMITED_AI_EMAILS=

# External lifecycle messaging stays disabled unless this is intentionally enabled.
ENABLE_STAGING_EMAILS=false
RESEND_API_KEY=
LOOPS_API_KEY=

# Optional: used by `npm run package:extension:staging`.
BECKETT_STAGING_SITE_URL=https://your-staging-url.vercel.app

# Optional: Slack Desktop app testing.
# Use a separate staging Slack app and worker so production Slack OAuth stays untouched.
SLACK_SIGNING_SECRET=replace_me
SLACK_OAUTH_WORKER_URL=https://your-staging-slack-oauth-worker.workers.dev
