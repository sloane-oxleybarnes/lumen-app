# Copy to .env.local or export these in your shell before seeding.
# Use dedicated demo credentials only. Double-check the target before seeding.

# Optional: makes seeded timestamps deterministic.
DEMO_BASE_TIME=2026-07-06T17:00:00.000Z

# Gmail mailbox seeding.
# Required OAuth scope: https://www.googleapis.com/auth/gmail.insert
DEMO_GMAIL_ACCESS_TOKEN=
DEMO_GMAIL_USER=me

# Slack workspace seeding.
# Required bot scope: chat:write. Invite the app to each target channel.
DEMO_SLACK_BOT_TOKEN=
DEMO_SLACK_DELAY_MS=1200
DEMO_SLACK_CHANNEL_MAP_JSON={"product_launch":"C0123456789","analytics_handoff":"C0123456790","client_scope":"C0123456791","team_leads":"C0123456792"}

# Optional Slack identity helpers.
# Use real Slack user IDs for confirmed Beckett contact linking.
DEMO_SLACK_TEAM_ID=T0123456789
DEMO_SLACK_USER_ID_MAP_JSON={"maya":"U0123456789","jordan":"U0123456790","priya":"U0123456791","sam":"U0123456792","eli":"U0123456793"}

# Optional: user tokens let seeded Slack messages be authored by real demo users.
# If omitted, the bot posts the corpus and prefixes the speaker name.
DEMO_SLACK_PERSONA_TOKENS_JSON={"maya":"xoxp-demo-user-token"}

# Optional: only use if the Slack app has chat:write.customize and the workspace
# expects the app to visually customize bot-authored demo messages.
DEMO_SLACK_USE_CUSTOMIZE=false

# Beckett contact seeding. Requires the Phase 4 migration first.
DEMO_SUPABASE_URL=
DEMO_SUPABASE_SERVICE_ROLE_KEY=
DEMO_BECKETT_USER_ID=
